# B2 Moves - Environment Configuration

# --- Telegram Configuration ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Redis Configuration (Queue & Nonce) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Solana RPC Configuration ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=your_helius_key
SOLANA_QUICKNODE_RPC=https://your-endpoint.solana-mainnet.quiknode.pro/your_token/
SOLANA_COMMITMENT=confirmed

# --- Vanish API (Privacy Layer) ---
VANISH_API_KEY=your_vanish_api_key_here
VANISH_API_URL=https://api.vanish.example.com

# --- Jupiter API (DEX Aggregator) ---
JUPITER_API_URL=https://quote-api.jup.ag/v6

# --- Frontend / Signer Configuration ---
# Use your local IP (e.g., http://192.168.1.5:5173) for mobile testing
FRONTEND_URL=https://b2moves.io
NODE_ENV=development
